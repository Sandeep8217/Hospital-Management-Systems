<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Registration</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/5.0.0/css/flag-icon.min.css"> <!-- Flag icons -->
    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: url('/images/Screenshot\ 2024-12-17\ 111102.png') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Arial', sans-serif;
            display: flex;
            justify-content: center; /* Align content to the right */
            align-items: center;
            position :relative;
        }

      
   .registration-container {
    position: absolute;
    top: 0;
    right: 0; /* Aligns the form to the right */
    width: 50%; /* Adjust width as needed */
    height: 100%; /* Covers full height */
    background: rgba(255, 255, 255, 0.95); /* Slightly transparent white background */
    box-shadow: -4px 0 10px rgba(0, 0, 0, 0.2); /* Shadow to overlay effect */
    border-radius: 0; /* Remove border-radius for full coverage */
    padding: 40px 30px;
    overflow-y: auto; /* Scroll if content exceeds height */
        }


        h3 {
            text-align: center;
            font-weight: bold;
            margin-bottom: 20px;
            color: #333;
        }

        .form-group label {
            font-weight: bold;
            margin-bottom: 5px;
        }

        .form-control {
            font-size: 1rem;
            padding: 8px 10px;
            border-radius: 5px;
            border: 1px solid #ddd;
        }

        .btn-primary {
            font-size: 1.2rem;
            font-weight: bold;
            background-color: #ff7b00;
            border: none;
            width: 100%;
            margin-top: 15px;
            color: #fff;
            transition: background 0.3s;
        }

        .btn-primary:hover {
            background-color: #e56800;
        }

        .scrollable-form {
            max-height: 500px;
            overflow-y: auto;
        }

        .scrollable-form::-webkit-scrollbar {
            width: 8px;
        }

        .scrollable-form::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        .scrollable-form::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 10px;
        }
        @media (max-width: 768px) { /* Mobile and small devices */
    .registration-container {
        position: static; /* Remove absolute positioning */
        margin: 20px auto; /* Center the form horizontally */
        width: 90%; /* Adjust the width for mobile screens */
        height: auto; /* Allow the form to expand naturally */
        padding: 20px; /* Reduce padding for smaller screens */
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2); /* Add a subtle shadow */
        border-radius: 10px; /* Rounded corners */
    }
}

    </style>
</head>
<body>
    <!-- Registration Form Container -->
    <div class="registration-container">
        <h3>Register</h3>
        <form action="/register" method="POST" class="scrollable-form">
            <div class="form-group">
                <label for="username">Full Name</label>
                <input type="text" class="form-control" id="username" name="username" required>
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" class="form-control" id="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" class="form-control" id="password" name="password" required>
            </div>
            <div class="form-group">
                <label for="dob">Date of Birth</label>
                <input type="date" class="form-control" id="dob" name="dob" required>
            </div>
            <div class="form-group">
                <label for="gender">Gender</label>
                <select class="form-control" id="gender" name="gender" required>
                    <option value="">Select Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label for="mobile">Mobile Number</label>
                <input type="tel" class="form-control" id="mobile" name="mobile" required pattern="\d*" minlength="10">
            </div>
            <div class="form-group">
                <label for="address">Address</label>
                <textarea class="form-control" id="address" name="address" rows="2" required></textarea>
            </div>
            <div class="form-group">
                <label for="reason">Reason for Visit / Current Symptoms</label>
                <textarea class="form-control" id="reason" name="reason" rows="2" required></textarea>
            </div>
            <div class="form-group">
                <label for="emergencyName">Emergency Contact Name</label>
                <input type="text" class="form-control" id="emergencyName" name="emergencyName" required>
            </div>
            <div class="form-group">
                <label for="emergencyNumber">Emergency Contact Number</label>
                <input type="text" class="form-control" id="emergencyNumber" name="emergencyNumber" required>
            </div>
            <div class="form-group">
                <label for="bloodGroup">Blood Group</label>
                <select class="form-control" id="bloodGroup" name="bloodGroup" required>
                    <option value="">Select Blood Group</option>
                    <option value="A+">A+</option>
                    <option value="B+">B+</option>
                    <option value="O+">O+</option>
                    <option value="AB+">AB+</option>
                    <option value="A-">A-</option>
                    <option value="B-">B-</option>
                    <option value="O-">O-</option>
                    <option value="AB-">AB-</option>
                </select>
            </div>
            <div class="form-group">
                <label for="allergies">Allergies</label>
                <textarea class="form-control" id="allergies" name="allergies" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>

    <!-- JavaScript -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
