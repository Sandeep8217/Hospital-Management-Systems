<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Bootstrap CSS CDN -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        /* Background Image */
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: url('/images/Screenshot\ 2024-12-17\ 103932.png') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Arial', sans-serif;
        }

        /* Heading */
        h2 {
            text-align: center;
            margin-top: 20px;
            color: #ffffff;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.4);
        }

        /* Buttons Style */
        .btn {
            font-size: 2.5rem;
            font-weight: bold;
            border: none;
            border-radius: 50px; /* Makes semicircle edges */
            box-shadow: 0px 5px 10px rgba(0, 0, 0, 0.3);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0px 10px 20px rgba(0, 0, 0, 0.5);
            color : black;
        }

        /* Button Colors */
        .btn-primary { background-color: #4caf50; color: #ffffff; }
        .btn-success { background-color: #ff9800; color: #ffffff; }
        .btn-info { background-color: #03a9f4; color: #ffffff; }
        .btn-warning { background-color: #ff5722; color: #ffffff; }
        .btn-danger { background-color: #f44336; color: #ffffff; }

        /* Container Styling */
        .row {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 30px auto;
        }

        .col-md-6 {
            padding: 15px; /* Adds spacing around buttons */
        }
    </style>
</head>
<body>
    <!-- Page Title -->
    <h2>Welcome</h2>

    <!-- Buttons Container -->
    <div class="container">
        <div class="row">
            <div class="col-md-6 mb-3">
                <a href="/user/doctors" class="btn btn-primary btn-block">View Doctors</a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/User/appointments/new" class="btn btn-success btn-block">Book an Appointment</a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/user/viewAppointments" class="btn btn-info btn-block">View My Appointments</a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/User/messages/new" class="btn btn-warning btn-block">Message Admin</a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/user/viewMessages" class="btn btn-warning btn-block">View Messages</a>
            </div>
             <div class="col-md-6 mb-3">
            <a href="/user/pay" class="btn btn-primary btn-block">Pay Hospital Bill</a>
            </div>
            <div class="col-md-6 mb-3">
                <a href="/logout" class="btn btn-danger btn-block">Logout</a>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
