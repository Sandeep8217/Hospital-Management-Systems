<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Pay Hospital Bill</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    body {
      background: linear-gradient(135deg, #667eea, #764ba2);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .payment-card {
      background: #fff;
      border-radius: 1rem;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
      padding: 2rem 3rem;
      max-width: 400px;
      width: 100%;
      text-align: center;
    }
    h2 {
      color: #4b1979;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }
    .form-control {
      border-radius: 0.5rem;
      padding: 1rem;
      font-size: 1.1rem;
    }
    .btn-pay {
      background: #764ba2;
      color: white;
      font-weight: 600;
      border-radius: 0.5rem;
      padding: 0.75rem 1.5rem;
      font-size: 1.2rem;
      width: 100%;
      margin-bottom: 1rem;
    }
    .btn-pay:hover {
      background: #5a3670;
    }
    .btn-back {
      background: #6c757d;
      color: white;
      font-weight: 600;
      border-radius: 0.5rem;
      padding: 0.65rem 1.5rem;
      font-size: 1rem;
      width: 100%;
      text-decoration: none;
      display: inline-block;
    }
    .btn-back:hover {
      background: #5a6268;
    }
  </style>
</head>
<body>
  <div class="payment-card shadow">
    <h2>Pay Hospital Bill</h2>
    <form id="paymentForm">
      <input type="number" id="amount" min="1" placeholder="Enter amount in ₹" class="form-control mb-4" required />
      <button type="submit" class="btn btn-pay">Pay Now</button>
    </form>
    <a href="/user" class="btn-back">Back to Dashboard</a>
  </div>

  <script>
    document.getElementById('paymentForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const amount = document.getElementById('amount').value;
      if (amount < 1) {
        alert('Enter a valid amount');
        return;
      }

      const options = {
        "key": "rzp_test_T2eQMIernANwrM",
        "amount": amount * 100,
        "currency": "INR",
        "name": "Hospital Management System",
        "description": "Bill Payment",
        "handler": function(response) {
          alert("Payment successful! Payment ID: " + response.razorpay_payment_id);

          fetch('/user/save-payment', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_order_id: response.razorpay_order_id,
              razorpay_signature: response.razorpay_signature,
              amount: amount
            })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              alert('Payment details saved successfully!');
            } else {
              alert('Failed to save payment details.');
            }
          })
          .catch(err => {
            alert('Error saving payment details.');
            console.error(err);
          });
        },
        "prefill": {
          "name": "Patient Name",
          "email": "patient@example.com",
          "contact": "9999999999"
        },
        "theme": {
          "color": "#764ba2"
        }
      };

      const rzp1 = new Razorpay(options);
      rzp1.open();
    });
  </script>
</body>
</html>
